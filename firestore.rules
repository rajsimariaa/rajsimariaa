rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /enquiries/{enquiry} {
      // Anyone can submit an inquiry
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'date']);
      // Admin panel needs to read and update (for closing contracts)
      allow read, update, delete: if true;
    }

    match /affiliates/{affiliate} {
      // Anyone can check if a referral code exists, enroll, or login
      // Login check is done via query on referralCode/email and password
      allow read, create: if true;
      
      // Admin panel updates earnings and balance
      // Affiliates can only update their own profile (if implemented)
      allow update: if true; 
      allow delete: if true;
    }

    match /contracts/{contract} {
      // Contracts are created by admin
      // Read by admin for management AND by affiliates to see their conversion log
      allow read: if true;
      allow write: if true;
    }
  }
}

