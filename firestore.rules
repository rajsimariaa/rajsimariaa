rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'rajsimariaa@gmail.com';
    }

    // Helper: Check if user is authenticated and verified
    function isAuthenticated() {
      return request.auth != null && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    // Users Collection (Profile Data)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Payments / Orders
    match /payments/{paymentId} {
      // ANYONE can create a payment (Guest checkout)
      allow create: if true;
      
      // Users can read their own payments based on EMAIL
      allow read: if isAdmin() || (
        isAuthenticated() && 
        request.auth.token.email == resource.data.email
      );
      
      // Admin can verify (update)
      allow update: if isAdmin();
      
      // Users can delete their own pending payments
      allow delete: if isAdmin() || (
        isAuthenticated() && 
        request.auth.token.email == resource.data.email &&
        resource.data.status == 'pending_verification'
      );
    }

    // Works / Products
    match /works/{workId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
