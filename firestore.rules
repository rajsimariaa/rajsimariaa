rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ENQUIRIES: Handles lead capture
    match /enquiries/{enquiry} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    // AFFILIATES: Handles agent data and balances
    match /affiliates/{affiliate} {
      allow read, create, update, delete: if true;
    }

    // CONTRACTS: Handles finalized deal records
    match /contracts/{contract} {
      allow read, write: if true;
    }

    // GLOBAL: Allow read for any other collection if needed
    match /{document=**} {
      allow read: if true;
    }
  }
}
