rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /enquiries/{enquiry} {
      // Allow anyone to submit an inquiry with all required fields
      // (name, email, countryCode, phone, details)
      allow create: if true;
      
      // Allow the admin panel to fetch enquiries for management
      allow read: if true;
      
      // Prevent unauthorized modification or deletion of captured transmissions
      // Allow deletions (managed by the Clear Vault action in Admin Panel)
      allow delete: if true;
      allow update: if false;
    }
  }
}
